# Cloudinary - subida de imágenes desde el frontend
# 1. Cloud name: lo ves en Cloudinary Dashboard (ej. ecommerce, dnfbuijp1)
# 2. Upload preset: Settings → Upload → Upload presets → Add upload preset
#    - Modo: Unsigned
#    - Copia el nombre del preset (ej. ecommerce_unsigned)
VITE_CLOUDINARY_CLOUD_NAME=ecommerce
VITE_CLOUDINARY_UPLOAD_PRESET=tu_upload_preset
