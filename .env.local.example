# Copia este archivo como .env (en backend/) y rellena los valores.
# NUNCA subas archivos .env con credenciales reales a Git.

# MongoDB Atlas - obtén la URI en https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/nombre-db?retryWrites=true&w=majority

# JWT / Auth - genera un string aleatorio seguro
TOKEN_SECRET=tu_secret_aqui
JWT_SECRET=tu_secret_aqui

# API de IA (opcional)
# Google: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# OpenAI
APIKEY_AI_SECRET=

# Cloudinary (opcional)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Frontend URL para CORS
ORIGIN=http://localhost:5173
